.form-field {
  display: flex;
  flex-direction: column;
  gap: 10px;
  padding: 16px 0;
  border-bottom: 1px solid #e8e8e8;
  width: 100%;
}

.field-label {
  display: flex;
  align-items: center;
  gap: 8px;
}

.optional-badge {
  background: #f0f0f0;
  color: #666;
  padding: 2px 8px;
  border-radius: 6px;
  font-size: 12px;
}

.field-counter {
  color: #bababa;
  font-size: 14px;
  text-align: right;
}

.flower-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
}

.flower-option {
  width: 52px;
  height: 52px;
  border-radius: 8px;
  cursor: pointer;
  transition: all 0.3s ease;
  opacity: 0.6;
}

.flower-option:hover {
  opacity: 0.8;
}

.flower-option.active {
  opacity: 1;
  border: 2px solid #333;
  background: #f5f5f5;
}

.font-selector {
  display: flex;
  flex-direction: column;
  gap: 8px;
  max-height: 280px;
  overflow-y: auto;
}

.font-option {
  padding: 12px 14px;
  border: 2px solid #e0d9d0;
  background: white;
  border-radius: 8px;
  cursor: pointer;
  transition: all 0.3s ease;
  text-align: left;
}

.font-option:hover {
  border-color: #c9bfb5;
  background: #fafaf8;
}

.font-option.active {
  border-color: #333;
  background: #f5f1ed;
}

